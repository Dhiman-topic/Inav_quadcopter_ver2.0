# iNav 7.1.1 Configuration Diff
# Board: Custom FC (STM32F405)
# Generated with: diff all
# Date: 2025-01-01
#
# HOW TO RESTORE:
# 1. Connect to iNav Configurator
# 2. Go to CLI tab
# 3. Paste this entire file
# 4. Type: save
# 5. Reboot the FC

# ----- MIXER -----
mixer QUADX

# ----- OUTPUTS -----
mmix reset
mmix 0  1.000  -1.000  1.000  -1.000
mmix 1  1.000  -1.000  -1.000  1.000
mmix 2  1.000  1.000  1.000  1.000
mmix 3  1.000  1.000  -1.000  -1.000

# ----- FEATURE FLAGS -----
feature -TX_PROF_SEL
feature GPS
feature TELEMETRY

# ----- RX -----
set receiver_type = SERIAL
set serialrx_provider = CRSF
set serialrx_inverted = OFF

# ----- GPS -----
set gps_provider = UBLOX
set gps_sbas_mode = AUTO
set gps_auto_config = ON
set gps_auto_baud = ON
set gps_ublox_use_galileo = ON

# ----- IMU -----
set gyro_hardware_lpf = 256HZ
set acc_hardware = BMI160
set baro_hardware = DPS310
set mag_hardware = NONE

# ----- RATES -----
set roll_rate = 70
set pitch_rate = 70
set yaw_rate = 60

# ----- PIDS (starting point — tune for your build) -----
set mc_p_pitch = 40
set mc_i_pitch = 30
set mc_d_pitch = 15
set mc_p_roll = 40
set mc_i_roll = 30
set mc_d_roll = 15
set mc_p_yaw = 85
set mc_i_yaw = 45
set mc_d_yaw = 0

# ----- BATTERY -----
set bat_cells = 3
set vbat_cell_detect_voltage = 430
set vbat_max_cell_voltage = 420
set vbat_min_cell_voltage = 320
set vbat_warning_cell_voltage = 340
set current_meter = ADC
set battery_meter = ADC

# ----- VTX -----
set vtx_band = 5
set vtx_channel = 8
set vtx_power = 4

# ----- FAILSAFE -----
set failsafe_procedure = RTH
set nav_rth_altitude = 1500

save
